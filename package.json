{
  "name": "previewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Autonomous, context-aware, multi-repo AI PR review orchestrator",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
